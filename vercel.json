{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "builds": [
    { "src": "**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/service-crm",     "dest": "/service-crm.html" },
    { "src": "/service-rpa",     "dest": "/service-rpa.html" },
    { "src": "/service-funnels", "dest": "/service-funnels.html" },
    { "src": "/service-revops",  "dest": "/service-revops.html" },
    { "src": "/our-approach",    "dest": "/our-approach.html" },
    { "src": "/who-we-are",      "dest": "/who-we-are.html" },
    { "src": "/insights",        "dest": "/insights.html" },
    { "src": "/contact",         "dest": "/contact.html" },
    { "src": "/privacy",         "dest": "/privacy.html" },
    { "src": "/security",        "dest": "/security.html" },
    { "src": "/terms",           "dest": "/terms.html" },
    { "src": "/",                "dest": "/index.html" }
  ]
}